{
  "name": "minhage",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "build": "pnpm -r run build",
    "dev:local": "bash scripts/dev-local.sh",
    "db:clean": "docker compose down -v --remove-orphans && docker compose -f docker-compose.dev.yml down -v --remove-orphans"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  }
}
